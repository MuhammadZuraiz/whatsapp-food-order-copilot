# Copy this file to apps/api/.env before running Prisma/API commands.
PORT=4000
DATABASE_URL="file:./dev.db"
CORS_ORIGIN=http://localhost:5173

# AI defaults to mock and works without any API key.
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Optional. Leave unset to use the Vite dev proxy during dashboard development.
VITE_API_BASE_URL=http://localhost:4000
