# Copy this file to apps/api/.env before running Prisma/API commands.
PORT=4000
DATABASE_URL="file:./dev.db"
CORS_ORIGIN=http://localhost:5173

# AI defaults to mock and works without any API key.
AI_PROVIDER=mock
AI_ANALYZER_ENABLED=true
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Recommended first real-provider shape, using a generic OpenAI-compatible API.
# Do not commit real keys.
# Groq example:
# AI_PROVIDER=openai-compatible
# AI_ANALYZER_ENABLED=true
# AI_API_KEY=your_groq_api_key
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=<choose a currently available Groq chat model>
#
# OpenRouter example:
# AI_PROVIDER=openai-compatible
# AI_ANALYZER_ENABLED=true
# AI_API_KEY=your_openrouter_api_key
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openrouter/free

# Optional. Leave unset to use the Vite dev proxy during dashboard development.
VITE_API_BASE_URL=http://localhost:4000
