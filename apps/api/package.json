{
  "name": "@wfo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @wfo/shared build && tsx watch src/server.ts",
    "build": "pnpm --filter @wfo/shared build && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "pnpm --filter @wfo/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wfo/shared": "workspace:*",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
